# Copy to `.env` and adjust for your environment. `docker compose up` works with the
# built-in defaults even without a .env file, but you SHOULD override the secrets in production.

# --- Database ---
POSTGRES_USER=recruit_app
POSTGRES_PASSWORD=Recruit@2026!
POSTGRES_DB=recruitment_platform

# --- API security (CHANGE THESE IN PRODUCTION) ---
# Must be a long, random string (HS256 signing key, >= 32 bytes).
JWT_KEY=please-change-this-to-a-long-random-secret-in-production-0123456789ABCDEF

# --- AI (Claude) ---
# Optional. Without a key the AI endpoints still work, using deterministic heuristics instead of
# the model. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Email (SMTP) ---
# Optional. With no SMTP_HOST the platform logs emails instead of sending them, so everything
# still works — but password-reset links will not reach users.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@getcareers.local
MAIL_FROM_NAME=GetCareers

# --- SMS (Twilio) ---
# Optional. With no credentials the platform logs SMS instead of sending them.
# Find these at https://console.twilio.com/. FROM must be E.164, e.g. +15551234567
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Interview reminders ---
# Lead times in minutes before an interview at which reminders are sent (default 24h and 1h).
REMINDERS_ENABLED=true
REMINDER_FIRST_MINUTES=1440
REMINDER_SECOND_MINUTES=60

# --- Host ports & origins ---
WEB_PORT=8080
API_PORT=5080
WEB_ORIGIN=http://localhost:8080
